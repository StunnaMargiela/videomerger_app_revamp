# Environment Configuration
# Copy this file to .env and update values as needed

# Flask Configuration
FLASK_APP=src/videomerger/app.py
FLASK_ENV=development
SECRET_KEY=dev-secret-key-change-in-production

# Server Configuration
HOST=0.0.0.0
PORT=5000
DEBUG=True

# File Upload Configuration
UPLOAD_FOLDER=src/videomerger/static/uploads
OUTPUT_FOLDER=src/videomerger/static/outputs
MAX_CONTENT_LENGTH=524288000  # 500MB in bytes

# Video Processing Configuration
MAX_VIDEOS_PER_MERGE=10
DEFAULT_OUTPUT_FORMAT=mp4

# Google OAuth (do not commit real values)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must also be added as an Authorized redirect URI in Google Cloud
GOOGLE_REDIRECT_URI=http://localhost:8976/oauth2callback

# Optional alternative to the variables above:
# Provide either inline JSON or a path to your Google client secret JSON file.
# GOOGLE_OAUTH_CLIENT_JSON={"installed":{"client_id":"...","client_secret":"...","redirect_uris":["http://localhost:8976/oauth2callback"]}}
# GOOGLE_OAUTH_CLIENT_JSON_FILE=C:/Users/your-user/Downloads/client_secret_xxx.apps.googleusercontent.com.json
