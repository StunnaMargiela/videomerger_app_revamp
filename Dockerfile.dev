# Development environment containing Python, Node.js, FFmpeg, and Electron dependencies
FROM node:18-bookworm

# Install Python, FFmpeg, and required X11 libraries for Electron
RUN apt-get update && \
    apt-get install -y \
    python3 python3-pip python3-venv \
    ffmpeg \
    # Electron runtime deps
    libgtk-3-0 libnss3 libnspr4 libatk1.0-0 libatk-bridge2.0-0 libcups2 libdrm2 \
    libxkbcommon0 libxcomposite1 libxdamage1 libxfixes3 libxrandr2 \
    libgbm1 libxshmfence1 libasound2 xvfb \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app
